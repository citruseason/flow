{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/session-start.sh\"",
            "timeout": 5000
          }
        ],
        "description": "Reinject context on resume/compact, welcome on startup"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git merge *)",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/post-merge.sh\"",
            "timeout": 5000
          }
        ],
        "description": "Detect git merge and trigger /core-update"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git pull *)",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/post-merge.sh\"",
            "timeout": 5000
          }
        ],
        "description": "Detect git pull (remote merge) and trigger /core-update"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/stop-summary.sh\"",
            "timeout": 3000
          }
        ],
        "description": "Output kanban progress summary for active topics"
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/subagent-kanban.sh\"",
            "timeout": 5000
          }
        ],
        "description": "Auto-update kanban.json step transitions during implement phase"
      }
    ]
  }
}
